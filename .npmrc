node-linker=isolated
store-dir=~/.pnpm-store
engine-strict=true

# @crossub-thongz/api-contract — published to GitHub Packages from crossub_web.
# Supply GITHUB_TOKEN (read:packages) via the environment (local + Render).
@crossub-thongz:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
