{
  "name": "crossub-mobile-maintenance",
  "version": "0.1.0",
  "private": true,
  "description": "CROSSUB maintenance app — mobile-first PWA for repair suppliers and contractors (consumes crossub_web API).",
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev": "bash scripts/dev-clean.sh",
    "dev:raw": "pnpm -r --parallel run dev",
    "dev:maintenance": "pnpm --filter @crossub/maintenance dev",
    "build": "pnpm -r run build",
    "build:maintenance": "pnpm --filter @crossub-thongz/api-contract build && pnpm --filter @crossub/maintenance build",
    "start": "pnpm -r --parallel run start",
    "start:maintenance": "pnpm --filter @crossub/maintenance start",
    "lint": "pnpm -r run lint"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  }
}
